# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------

# Chave secreta do Django (obrigatória — mínimo 50 caracteres)
SECRET_KEY=change-me-to-a-random-secret-key-minimum-50-characters-long

# Modo debug (True para desenvolvimento, False para produção)
DEBUG=False

# Domínios permitidos (separados por vírgula)
# Em produção, liste apenas os domínios reais
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Banco de Dados PostgreSQL
# ---------------------------------------------------------------------------

DB_NAME=postgres
DB_USER=hectare_app
DB_PASSWORD=change-me-to-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# Configurações opcionais
# ---------------------------------------------------------------------------

# Para rodar com docker-compose, o DB_HOST é sobrescrito para "db"
# DB_HOST=db
